# =========================================================================
# Configuration for Private Vietnamese Text-to-Speech Web Application
# Copy this file to `.env.local` and fill in the values below.
# =========================================================================

# 1. Custom Access Security Passcode
# This passcode will restrict access to your private app.
# Users will need to enter this passcode on their first visit.
APP_ACCESS_PASSCODE=my_secret_passcode_here

# 2. Google Cloud Service Account Credentials
# Create a Service Account, enable the "Cloud Text-to-Speech API" in your project,
# and download the JSON key. Paste the corresponding values here:
GOOGLE_PROJECT_ID=your-google-cloud-project-id
GOOGLE_CLIENT_EMAIL=your-service-account-email@your-project-id.iam.gserviceaccount.com

# Copy the entire contents of the "private_key" field from the JSON credentials file.
# Note: Ensure the private key starts with "-----BEGIN PRIVATE KEY-----\n" and
# includes all newline characters represented as "\n" or literal newlines.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC6...\n-----END PRIVATE KEY-----\n"
